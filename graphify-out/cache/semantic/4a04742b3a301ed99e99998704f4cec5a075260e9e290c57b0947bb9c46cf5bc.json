{"nodes": [{"id": "documentation_architecture_desktop_desktop_architecture", "label": "Desktop Architecture", "file_type": "document", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_desktop_tracking_engine", "label": "Desktop Tracking Engine", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Combines event-driven NSWorkspace app-activation notifications with a 1-5s polling loop for window titles, since window switches within one app fire no activation event."}, {"id": "documentation_architecture_desktop_window_inspector", "label": "Window Inspector (Accessibility API primary, CGWindowList fallback)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AXUIElement is the primary title source; CGWindowList (kCGWindowName) is the fallback and requires Screen Recording permission \u2014 if denied, the client degrades gracefully to app-name-only tracking."}, {"id": "documentation_architecture_desktop_state_machine", "label": "Tracking State Machine (active/idle/locked/sleeping)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Idle threshold defaults to 300s via CGEventSource; on crossing, the active segment is back-dated to the last-input instant (kept precision: exact) and the derived idle boundary is precision: approximate; MVP back-fill discards gaps as unattributed events (RIZ-39 decision, revisitable)."}, {"id": "documentation_architecture_desktop_event_store", "label": "Offline-first Event Store (SQLite via GRDB) with Outbox", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Events are always written locally first regardless of network state; an outbox table tracks unsent rows, and rows are marked synced only after server acknowledgment \u2014 no optimistic marking."}, {"id": "documentation_architecture_desktop_sync_client", "label": "Desktop Sync Client (60s / 500-event flush, exponential backoff)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_desktop_event_model", "label": "Desktop Event Model (UUIDv7 ids, 5s minimum duration, immutable rows)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "UUIDv7 gives idempotent ingestion plus natural local sort order; sessions under 5 seconds are dropped as focus-flicker noise; the local schema mirrors the server ingest contract in database-schema.md."}, {"id": "documentation_architecture_desktop_permissions", "label": "Desktop Permissions (Accessibility, Screen Recording, no App Sandbox)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "App Sandbox is explicitly not used because the Accessibility API is incompatible with it, which is also why distribution is Developer ID rather than the Mac App Store."}, {"id": "documentation_architecture_desktop_privacy_controls", "label": "Desktop Privacy Controls (exclusion list, title toggle, incognito filtering)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_system_overview_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_architecture_mobile_mobile_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_architecture_backend_backend_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_sync_protocol_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_database_schema_database_schema", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop_desktop_architecture", "target": "documentation_security_security", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_a