{"nodes": [{"id": "rize_mobile_claude_guidelines", "label": "rize-mobile Engineering Guidelines (CLAUDE.md)", "file_type": "document", "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tokens live in the Keychain, never UserDefaults; local store uses iOS Data Protection completeUntilFirstUserAuthentication; extension targets stay minimal with no app-level dependencies."}, {"id": "rize_mobile_claude_tier_a_report_extension", "label": "Tier A: DeviceActivityReport Extension (Display-Only Exact Usage)", "file_type": "concept", "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Apple blocks network calls and shared-container writes from the DeviceActivityReport extension at the OS level; any code attempting either is an automatic HIGH-severity review finding. Exact usage data is display-only inside the extension."}, {"id": "rize_mobile_claude_tier_b_monitor_extension", "label": "Tier B: DeviceActivityMonitor Threshold Events (Approximate)", "file_type": "concept", "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Threshold-derived usage events from the DeviceActivityMonitor extension reach the app via the App Group and must be flagged precision: approximate before sync; the UI must label them as approximate."}], "edges": [{"source": "rize_mobile_claude_guidelines", "target": "rize_desktop_claude_guidelines", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "documentation_api_reference", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "documentation_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "documentation_architecture_mobile", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "rize_mobile_claude_tier_a_report_extension", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "rize_mobile_claude_tier_b_monitor_extension", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_tier_b_monitor_extension", "target": "documentation_sync_protocol", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "rize_mobile_claude_guidelines", "target": "rize_clone_claude_git_flow", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "rize-mobile/CLAUDE.md", "source_location": null, "weight": 1.0}], "hyperedges": []}