{"nodes": [{"id": "documentation_architecture_backend_backend_architecture", "label": "Backend Architecture", "file_type": "document", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_backend_modular_monolith", "label": "Modular Monolith Service Shape", "file_type": "rationale", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deliberate choice against microservices: single-transaction consistency for ingestion/resolution/aggregation, lower operational cost for a small team, and package boundaries (auth/sync/reports/store) preserve the option to extract services later."}, {"id": "documentation_architecture_backend_layering", "label": "Strict Layering: handlers -> services -> repositories -> PostgreSQL", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_backend_middleware_stack", "label": "Middleware Stack (RequestID, Logging, Recoverer, CORS, RateLimit, Auth, RBAC)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ordering is deliberate: request ID/logging wrap everything for traceability, recoverer sits outside business logic to catch all panics, CORS/rate-limit reject abusive traffic before per-user work, and RBAC only runs after auth establishes identity."}, {"id": "documentation_architecture_backend_ingestion_pipeline", "label": "Ingestion Pipeline (validate, app resolution, category resolution, idempotent upsert)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Batch is validated before any DB work so malformed batches fail cheaply; the apps catalog grows organically from observed bundle_ids; category resolves via user_app_settings override then app default; upsert by client UUIDv7 deduplicates retries without editing committed events."}, {"id": "documentation_architecture_backend_aggregation_strategy", "label": "Aggregation Strategy (TimescaleDB continuous aggregates, device-aware capping)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Continuous real-time aggregates replace hand-rolled rollup jobs; closed-period queries cap each device's total_s at the window length (an upper bound, not the raw path's exact interval-merge, so it can overstate totals when merged coverage does not span the window); cross-device overlap stays additive."}, {"id": "documentation_architecture_backend_background_jobs", "label": "Background Jobs (token cleanup, retention, GDPR executor, changelog pruning)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Jobs run as scheduled goroutines inside the same binary, consistent with the modular-monolith shape; changelog pruning advances sync_changelog_horizon in the same transaction as each batch delete."}, {"id": "documentation_architecture_backend_forward_only_migrations", "label": "Forward-only Migration Policy (golang-migrate)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Migrations are never edited or rolled back once applied to a shared environment, keeping the history a replayable audit trail; TimescaleDB objects are also hard to express as automatic down migrations."}], "edges": [{"source": "claude_containerization_rule", "target": "documentation_architecture_backend_backend_architecture", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend_backend_architecture", "target": "documentation_system_overview_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend_backend_architecture", "target": "documentation_architecture_desktop_desktop_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend_backend_architecture", "target": "documentation_architecture_mobile_mobile_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend_backend_architecture", "target": "documentation_sync_protocol_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend_backend_architecture", "target": "documentation_api_reference_api_reference", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": 