{"nodes": [{"id": "documentation_architecture_mobile", "label": "Mobile Architecture", "file_type": "document", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_mobile_three_tier_model", "label": "Three-Tier Hybrid Screen Time Model (Tier A/B/C)", "file_type": "rationale", "source_file": "documentation/architecture-mobile.md", "source_location": "Three-Tier Hybrid Model", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exact per-app Screen Time data can only be read inside the network- and file-isolated DeviceActivityReport extension, so exact data can be displayed but never exported or synced. This OS-enforced boundary forces three tiers: A exact display-only, B approximate (\u00b15 min) synced via threshold events, C manual timers/focus sessions exact and synced. UX must label Tier B data approximate and show provenance in blended reports."}, {"id": "documentation_architecture_mobile_deviceactivityreport_extension", "label": "DeviceActivityReport Extension (Tier A)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": "Tier A", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Renders exact per-app usage as a SwiftUI view composited into the host app, but is deliberately network- and file-isolated by iOS: nothing it computes can be written to the App Group, sent over the network, or persisted for sync \u2014 an architectural dead end that exists purely for accurate in-the-moment display."}, {"id": "documentation_architecture_mobile_deviceactivitymonitor_extension", "label": "DeviceActivityMonitor Extension (Tier B thresholds)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": "Tier B / Threshold-Event Strategy", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Configured with a daily DeviceActivitySchedule and DeviceActivityEvent thresholds firing at 5-minute increments per tracked app/category; each callback writes a coarse usage record to the App Group. Woken by the system only on threshold crossings, keeping battery cost low; the only synced source of per-app breakdown data, hence the \u00b15 min approximate precision."}, {"id": "documentation_architecture_mobile_app_group_container", "label": "App Group Container group.com.rizeclone.shared", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": "Components", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The only channel through which Tier B data crosses from the monitor extension into the main app; an on-device shared-container handoff, not a network call."}, {"id": "documentation_architecture_mobile", "label": "Mobile Architecture (doc)", "file_type": "document", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_architecture_mobile", "target": "documentation_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile", "target": "documentation_architecture_desktop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile", "target": "documentation_architecture_backend", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, 