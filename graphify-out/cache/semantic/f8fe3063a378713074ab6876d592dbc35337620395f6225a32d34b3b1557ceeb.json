{"nodes": [{"id": "documentation_sync_protocol", "label": "Sync Protocol", "file_type": "document", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_sync_protocol_push_endpoint", "label": "Sync Push (POST /v1/sync/events)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": "Push", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Clients push their local outbox in batches of at most 500 items; per-item results (applied/duplicate/invalid) allow partial success so one invalid item never rejects a whole batch."}, {"id": "documentation_sync_protocol_pull_endpoint", "label": "Sync Pull (GET /v1/sync/changes)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": "Pull", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Keyset pagination over server_seq with an opaque cursor makes pulls idempotent and safe to repeat: the same cursor returns the same page and re-applying it is a no-op, which is what makes cursor loss and full re-pull after device restore safe without special-cased recovery logic. Applying pulled changes and persisting the new cursor must share one local transaction."}, {"id": "documentation_sync_protocol_clock_skew", "label": "Clock Skew Handling (24h Bound)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": "Edge Cases / Clock Skew", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If a client's clock is skewed more than 24 hours from server time, the server substitutes its own time before the LWW comparison, bounding how far a misconfigured client clock can distort ordering across devices at the cost of that write being ordered by arrival time."}, {"id": "documentation_sync_protocol_precision_semantics", "label": "Precision Semantics (exact vs approximate)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": "Precision Semantics", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "exact events reflect directly observed boundaries (desktop continuous observation); approximate events derive from iOS DeviceActivityMonitor threshold callbacks that only signal usage crossing a boundary, not precise start/stop instants. Reports can filter by precision to scope to strictly-observed time."}, {"id": "documentation_sync_protocol", "label": "Sync Protocol (contract doc)", "file_type": "document", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_sync_protocol", "target": "documentation_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol", "target": "documentation_architecture_desktop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol", "target": "documentation_architecture_mobile", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol", "target": "documentation_architecture_backend", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol", "target": "documentation_api_reference", "relation": "references", "conf