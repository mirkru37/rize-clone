{"nodes": [{"id": "documentation_architecture_mobile_mobile_architecture", "label": "Mobile Architecture", "file_type": "document", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_mobile_apple_constraint", "label": "Apple Screen Time Constraint (DeviceActivityReport isolation)", "file_type": "rationale", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exact per-app usage is only readable inside the network- and file-isolated DeviceActivityReport extension, so it can be displayed but never exported or synced \u2014 a hard OS boundary that forces the three-tier hybrid model instead of desktop's single-source-of-truth model."}, {"id": "documentation_architecture_mobile_three_tier_model", "label": "Three-Tier Hybrid Model (A exact/display-only, B approximate/synced, C exact/synced)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_mobile_threshold_strategy", "label": "Tier B Threshold-Event Strategy (DeviceActivityMonitor, 5-min increments)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Threshold callbacks at 5-minute increments write coarse records to the App Group container; the +/-5 min granularity is the source of the approximate precision tag; day-boundary schedule rollover is a hard aggregation boundary; battery cost stays low because the extension is only woken on threshold crossings."}, {"id": "documentation_architecture_mobile_local_store", "label": "Mobile Local Store (GRDB or SwiftData)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_mobile_sync_client", "label": "Mobile Sync Client (BGAppRefreshTask-driven)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_mobile_pause_semantics", "label": "Tier C Pause Semantics: Wall-Clock Authoritative (MVP)", "file_type": "rationale", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recorded focus-session duration is the wall-clock span including pauses because excluding paused time would require a focus_sessions schema/contract change (e.g. paused_total_s) synced through the protocol; pause state stays client-only view state. Decided in the RIZ-44 review, final for MVP, follow-up deferred post-MVP."}, {"id": "documentation_architecture_mobile_ux_honesty", "label": "UX Honesty Requirement (approximate labels, tier provenance)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every synced historical per-app number is Tier B and thus approximate by construction; presenting it with Tier A precision would misrepresent what the app can measure, so approximate labeling and provenance in blended reports are non-negotiable."}, {"id": "documentation_architecture_mobile_family_controls_entitlement", "label": "Family Controls Entitlement (App Store approval schedule risk)", "file_type": "concept", "source_file": "documentation/architecture-mobile.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "com.apple.developer.family-controls works in development by enabling the capability but App Store distribution requires a separate Apple request that typically takes weeks \u2014 an explicit schedule risk to request early."}], "edges": [{"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_system_overview_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_architecture_desktop_desktop_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_architecture_backend_backend_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_sync_protocol_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_database_schema_database_schema", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-mobile.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_mobile_mobile_architecture", "target": "documentation_security_security", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 