{"nodes": [{"id": "documentation_sync_protocol_sync_protocol", "label": "Sync Protocol", "file_type": "document", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_sync_protocol_entity_classes", "label": "Three Entity Classes (append-only, mutable-LWW, server-derived)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Clients own raw events, the server owns derived data, and every client record is idempotent by construction \u2014 these three rules eliminate the need for a general-purpose conflict-resolution engine; only mutable entities need any conflict handling (LWW)."}, {"id": "documentation_sync_protocol_idempotency_uuidv7", "label": "Idempotency by Client-generated UUIDv7", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_sync_protocol_lww", "label": "Last-Write-Wins Conflict Resolution (client updated_at)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_sync_protocol_pull_cursor", "label": "Opaque Commit-ordered Pull Cursor", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The cursor is a commit-ordered watermark, not the last server_seq seen; snapshot-consistent reads plus a transaction-visibility horizon guarantee no row is ever skipped even under concurrent writes \u2014 slow-committing rows are deferred to a later page, never half-included. Pulled changes and the new cursor must persist in one local transaction (relaxation permitted only in the apply-first direction)."}, {"id": "documentation_sync_protocol_cursor_expiry", "label": "Retention and Cursor Expiry (410 Gone recovery)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A non-empty cursor strictly below the pruned horizon gets 410 Gone; recovery is exactly the device-restore path \u2014 discard the cursor and re-pull from the beginning, safe because pulls are idempotent."}, {"id": "documentation_sync_protocol_clock_skew", "label": "Clock Skew Handling (24h bound, server-time substitution)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rejecting client timestamps skewed over 24 hours and substituting server time bounds how far a misconfigured clock can distort LWW ordering, at the cost of that write being ordered by arrival time."}, {"id": "documentation_sync_protocol_device_restore", "label": "Device Restore from Backup (idempotent full re-pull)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_sync_protocol_duplicate_device_ids", "label": "Duplicate Device IDs Edge Case", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cross-user reuse is rejected by the devices schema at registration; the same-user backup-restore case is tolerated by construction because idempotency and LWW never key on device_id \u2014 the only degradation is blurred per-device attribution. Mitigation is client-side ThisDeviceOnly Keychain storage (mobile currently uses AfterFirstUnlock, hardening tracked as RIZ-50)."}, {"id": "documentation_sync_protocol_overlap_rules", "label": "Overlap Rules (no trimming at ingestion, report-time capping)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Trimming raw event boundaries at push time would mean the server editing raw events, violating Principle 1; so same-device overlaps are ingested as reported and trimmed at report/aggregation time, while cross-device overlaps stand because simultaneous desktop and mobile activity is genuine."}, {"id": "documentation_sync_protocol_precision_semantics", "label": "Precision Semantics (exact vs approximate)", "file_type": "concept", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "approximate marks iOS threshold-derived events that only bound usage within an interval; report queries can filter by precision to scope to strictly-observed time or include the coarser iOS signal."}, {"id": "documentation_sync_protocol", "label": "Sync Protocol Specification", "file_type": "document", "source_file": "documentation/sync-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_security_keychain_storage", "target": "documentation_sync_protocol_duplicate_device_ids", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_system_overview_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_architecture_desktop_desktop_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_architecture_mobile_mobile_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_architecture_backend_backend_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_api_reference_api_reference", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_database_schema_database_schema", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_sync_protocol", "target": "documentation_security_security", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_entity_classes", "target": "documentation_sync_protocol_lww", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_entity_classes", "target": "documentation_sync_protocol_idempotency_uuidv7", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_clock_skew", "target": "documentation_sync_protocol_lww", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_device_restore", "target": "documentation_sync_protocol_cursor_expiry", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_pull_cursor", "target": "documentation_sync_protocol_cursor_expiry", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_overlap_rules", "target": "documentation_architecture_backend_aggregation_strategy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}, {"source": "documentation_sync_protocol_precision_semantics", "target": "documentation_database_schema_activity_events", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/sync-protocol.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "end_to_end_sync_flow", "label": "End-to-end Sync Flow (clients push/pull through the changelog-anchored protocol)", "nodes": ["documentation_architecture_desktop_sync_client", "documentation_architectur