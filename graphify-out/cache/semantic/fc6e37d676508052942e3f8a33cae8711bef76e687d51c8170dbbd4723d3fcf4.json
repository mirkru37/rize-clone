{"nodes": [{"id": "documentation_security_security", "label": "Security", "file_type": "document", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_security_token_model", "label": "Token Model (15-min RS256 JWT + 30-day opaque refresh)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Short-lived access tokens bound the leak exposure window and carry sub/role/device_id claims for DB-free authorization; refresh tokens are high-entropy opaque values hashed with SHA-256 (deliberately not argon2id \u2014 no guessing risk to defend, and validation stays a cheap indexed lookup); RS256 is enforced against algorithm-confusion attacks."}, {"id": "documentation_security_refresh_rotation", "label": "Refresh-token Rotation with Family Reuse Detection", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reuse of an already-rotated token is treated as theft: the whole device family is revoked, bounding a leaked refresh token's blast radius to one detected-and-revoked family instead of indefinite silent reuse."}, {"id": "documentation_security_sign_in_with_apple", "label": "Sign in with Apple (primary auth)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Identity tokens are verified against Apple's live JWKS with iss/aud/exp validation; accounts link by the stable apple_user_id sub claim, never by email, since Apple emails can be relay addresses."}, {"id": "documentation_security_argon2id", "label": "argon2id Password Hashing (64 MiB, 3 iterations, parallelism 4)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Passwords are capped at 1024 bytes and rejected before hashing because argon2id cost scales with input size \u2014 an unbounded password would be a per-request memory/CPU amplification DoS vector."}, {"id": "documentation_security_account_lockout", "label": "Account Lockout Policy (10 failures, escalating 15m-24h)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Keyed on the account, not source IP, so distributing attempts across many IPs still trips it; counters reset only on successful login, which is only possible after the lockout window elapses. Config via AUTH_LOCKOUT_* env vars (Go duration strings)."}, {"id": "documentation_security_no_oracle", "label": "No-Oracle Guarantee for Lockout State", "file_type": "rationale", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Locked-account and wrong-password paths return the identical invalid-credentials error and pay comparable argon2id cost, so callers cannot infer lockout state from response shape or timing."}, {"id": "documentation_security_rbac", "label": "RBAC (user/admin, user_id scoping at data-access layer)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every query is scoped by the token's sub claim at the data-access layer rather than per-handler, ruling out cross-tenant paths; admin routes live under /v1/admin gated by shared role-checking middleware."}, {"id": "documentation_security_rate_limiting", "label": "Token-bucket Rate Limiting (10/min per-IP auth, 60/min per-user sync)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_security_gdpr_lifecycle", "label": "GDPR Data Lifecycle (7-day grace deletion, JSON export, 72h breach notice)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_security_keychain_storage", "label": "Keychain-only Client Token Storage", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tokens must never touch UserDefaults or plist files; the sync protocol additionally wants device_id in Keychain with ThisDeviceOnly so it never migrates in a backup restore."}, {"id": "documentation_security_checklist", "label": "Security Checklist (canonical reviewer-citable requirements)", "file_type": "concept", "source_file": "documentation/security.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each item is independently verifiable in code/config/infra so a reviewer can check it without re-deriving it from prose."}], "edges": [{"source": "documentation_security_checklist", "target": "agents_code_reviewer_code_reviewer", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/security.md", "source_location": null, "weight": 1.0}, {"source": "documentation_security_security", "target": "documentation_system_overview_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/security.md", "source_location": null, "weight": 1.0}, {"source": "documentation_security_secur