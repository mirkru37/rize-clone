{"nodes": [{"id": "documentation_architecture_desktop", "label": "Desktop Architecture", "file_type": "document", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_desktop_tracking_engine", "label": "Desktop Tracking Engine", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": "Component Diagram / Tracking Pipeline", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Combines event-driven NSWorkspace didActivateApplicationNotification for app switches with a 1-5s polling loop for window titles (Accessibility API primary, CGWindowList fallback needing Screen Recording); a 5-second minimum-duration filter discards focus-flicker noise before writing immutable events."}, {"id": "documentation_architecture_desktop_state_machine", "label": "Desktop Tracking State Machine (active/idle/locked/sleeping)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": "Tracking State Machine", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "active->idle when CGEventSource secondsSinceLastEventType exceeds a 300s default; locked via com.apple.screenIsLocked; sleeping via NSWorkspace willSleep/didWake. Returning to active triggers a back-fill decision: discard the gap or prompt the user to attribute it."}, {"id": "documentation_architecture_desktop_event_store", "label": "Desktop Event Store (SQLite via GRDB, outbox)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": "Offline-First Store & Sync Loop", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Offline-first local database holding immutable activity_events plus a SQLite outbox table; the local schema mirrors the server ingest contract in database-schema.md and must be kept in sync with it."}, {"id": "documentation_architecture_desktop_sync_client", "label": "Desktop Sync Client (60s / 500-event flush)", "file_type": "concept", "source_file": "documentation/architecture-desktop.md", "source_location": "Offline-First Store & Sync Loop", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Flushes the outbox every 60 seconds or once 500 events accumulate, whichever comes first, with exponential backoff on failure; rows are marked synced only after server acknowledgment \u2014 no optimistic completion."}, {"id": "documentation_architecture_desktop", "label": "Desktop Architecture (doc)", "file_type": "document", "source_file": "documentation/architecture-desktop.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_architecture_desktop", "target": "documentation_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop", "target": "documentation_architecture_mobile", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop", "target": "documentation_architecture_backend", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_desktop", "target": "documentation_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-desktop.md", "source_location": null, "weight": 1.0}, {"source": "docum