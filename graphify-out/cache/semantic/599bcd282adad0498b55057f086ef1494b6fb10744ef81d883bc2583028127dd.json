{"nodes": [{"id": "documentation_architecture_backend", "label": "Backend Architecture", "file_type": "document", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_architecture_backend_modular_monolith", "label": "Modular Monolith Service Shape", "file_type": "rationale", "source_file": "documentation/architecture-backend.md", "source_location": "Service Shape", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One Go binary, one database, package-enforced module boundaries (handlers -> services -> repositories -> PostgreSQL). Chosen over microservices for transactional consistency across ingestion/resolution/aggregation, low operational cost for a small team, and boundaries that preserve the option to extract services later."}, {"id": "documentation_architecture_backend_middleware_stack", "label": "Backend Middleware Stack (Request ID, Logging, Recoverer, CORS, Rate limit, Auth, RBAC)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": "Middleware Stack", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ordering is deliberate: request ID and logging wrap everything so every request is traceable; the recoverer sits outside business logic so any downstream panic is caught; CORS and rate limiting reject abusive traffic before any per-user work; RBAC only makes sense after auth establishes the caller."}, {"id": "documentation_architecture_backend_ingestion_pipeline", "label": "Ingestion Pipeline (validate, app catalog resolution, category resolution, idempotent upsert)", "file_type": "concept", "source_file": "documentation/architecture-backend.md", "source_location": "Ingestion Pipeline", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Batch validation happens before any database work so malformed batches fail cheaply; the app catalog grows organically as unseen bundle_ids arrive; categories resolve via user override then app default; the final upsert dedupes retries by client UUIDv7, never edits committed events."}, {"id": "documentation_architecture_backend_forward_only_migrations", "label": "Forward-Only Migration Policy (golang-migrate)", "file_type": "rationale", "source_file": "documentation/architecture-backend.md", "source_location": "Migration Policy", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every schema change ships as a new numbered migration, never edited or reverted in place, keeping history a linear replayable audit trail \u2014 important because hypertables and continuous aggregates carry TimescaleDB-specific steps not straightforward to express as automatic down migrations."}, {"id": "documentation_architecture_backend", "label": "Backend Architecture (doc)", "file_type": "document", "source_file": "documentation/architecture-backend.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "documentation_architecture_backend", "target": "documentation_system_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend", "target": "documentation_architecture_desktop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "documentation_architecture_backend", "target": "documentation_architecture_mobile", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/architecture-backend.md", "source_location": null, "weight": 1.0}, {"source": "