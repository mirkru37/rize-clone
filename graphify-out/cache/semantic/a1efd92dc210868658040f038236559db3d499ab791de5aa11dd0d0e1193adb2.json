{"nodes": [{"id": "documentation_system_overview", "label": "System Overview", "file_type": "document", "source_file": "documentation/system-overview.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "documentation_system_overview_offline_first_clients", "label": "Offline-First Clients", "file_type": "rationale", "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Clients record activity and manage sessions locally first, independent of connectivity, because tracking must not be interrupted or lost by transient connectivity loss while capture runs continuously in the background."}, {"id": "documentation_system_overview_server_authoritative_aggregation", "label": "Server-Authoritative Aggregation", "file_type": "rationale", "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The backend is the source of truth for cross-device aggregation and reporting; unified cross-device reports need a single convergence point that only the backend can provide, so clients never merge each other's data locally."}, {"id": "documentation_system_overview_uuidv7_idempotency", "label": "Client-Generated UUIDv7 Idempotency", "file_type": "rationale", "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Offline-first clients may retry uploads after connectivity gaps; UUIDv7 generated on the client before the first network attempt is itself the idempotency key, time-ordered so it stays sortable while letting the backend deduplicate replayed uploads without a round trip to allocate an ID."}, {"id": "documentation_system_overview_last_write_wins", "label": "Last-Write-Wins Conflict Resolution", "file_type": "rationale", "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mutable entities (focus sessions, projects, tags, settings) reconcile by comparing client-supplied updated_at; LWW is a simple, low-coordination strategy where losing a rare concurrent edit is an acceptable tradeoff against sync complexity."}, {"id": "documentation_system_overview_append_only_events", "label": "Append-Only Immutable Activity Events", "file_type": "rationale", "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Raw activity events are never mutated after ingestion; corrections append new events. Matches the append-heavy time-series nature of the data and keeps the ingestion path simple and auditable."}], "edges": [{"source": "documentation_system_overview", "target": "documentation_architecture_desktop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_architecture_mobile", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_architecture_backend", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_sync_protocol", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_api_reference", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_database_schema", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview", "target": "documentation_security", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": null, "weight": 1.0}, {"source": "documentation_system_overview_offline_first_clients", "target": "documentation_system_overview_uuidv7_idempotency", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "weight": 1.0}, {"source": "documentation_system_overview_append_only_events", "target": "documentation_database_schema_activity_events_hypertable", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "documentation/system-overview.md", "source_location": "Key Architectural Decisions", "weight": 1.0}], "hyperedges": []}